generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (with connect_timeout for serverless cold starts) used at
  // runtime by API routes. The Vercel Neon integration injects this name.
  url       = env("POSTGRES_PRISMA_URL")
  // Unpooled connection used by `prisma migrate deploy` at build time and by
  // local `prisma migrate dev`. Pooled connections (PgBouncer) reject some DDL.
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

/// A DNS host (the IPTV provider's panel origin). Multiple credential
/// profiles can share one host (different accounts on the same provider).
model Dns {
  id    Int    @id @default(autoincrement())
  title String
  url   String @unique

  profiles CredentialProfile[]
}

/// A single (DNS host, username, password) credential bundle. Activation
/// codes and playlists reference this — when the provider rotates anything,
/// updating one profile row instantly propagates to every linked row via the
/// FK. No duplicated url/username/password columns anywhere downstream.
model CredentialProfile {
  id        Int      @id @default(autoincrement())
  title     String?
  dnsId     Int      @map("dns_id")
  username  String
  password  String
  /// Optional XMLTV EPG URL. When set, the EPG ingest job pulls programme
  /// data and matches it to channels by tvg-id (Channel.externalId).
  epgUrl    String?  @map("epg_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  dns             Dns                  @relation(fields: [dnsId], references: [id], onDelete: Restrict)
  activationCodes ActivationCode[]
  playlists       Playlist[]
  channels        Channel[]
  refreshLog      ChannelRefreshLog?
  epgChannels     EpgChannel[]
  epgRefreshLog   EpgRefreshLog?

  @@unique([dnsId, username, password])
  @@index([dnsId])
  @@map("credential_profiles")
}

/// Cached channel rows pulled from a profile's M3U. Server fetches +
/// parses + stores once per profile; the player API serves paginated
/// reads. Replaces the per-device Room channel cache in older builds.
model Channel {
  id         Int     @id @default(autoincrement())
  profileId  Int     @map("profile_id")
  externalId String  @map("external_id") // tvg-id when present, else hash
  name       String
  url        String
  logo       String?
  groupName  String? @map("group_name")
  category   String                       // live | movies | series | sports

  profile   CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@unique([profileId, externalId])
  @@index([profileId, category])
  @@index([profileId, category, groupName])
  @@map("channels")
}

/// XMLTV channel from the provider's EPG feed. The `epgChannelId` is the
/// raw `<channel id="...">` value — matched against `Channel.externalId`
/// (which carries tvg-id) to join programmes to playable channels.
model EpgChannel {
  id           Int    @id @default(autoincrement())
  profileId    Int    @map("profile_id")
  epgChannelId String @map("epg_channel_id")
  displayName  String @default("") @map("display_name")

  profile    CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  programmes EpgProgramme[]

  @@unique([profileId, epgChannelId])
  @@index([profileId])
  @@map("epg_channels")
}

/// A single EPG programme block. Indexed by (channel, start) so the "now
/// playing" lookup is a one-row scan: `WHERE channel = X AND start <= now
/// ORDER BY start DESC LIMIT 1`.
model EpgProgramme {
  id            Int      @id @default(autoincrement())
  epgChannelId  Int      @map("epg_channel_id")
  startUtc      DateTime @map("start_utc")
  stopUtc       DateTime @map("stop_utc")
  title         String   @default("")
  description   String?

  epgChannel EpgChannel @relation(fields: [epgChannelId], references: [id], onDelete: Cascade)

  @@index([epgChannelId, startUtc])
  @@index([epgChannelId, stopUtc])
  @@map("epg_programmes")
}

/// Tracks the most recent (or in-progress) EPG refresh per profile.
model EpgRefreshLog {
  id              Int       @id @default(autoincrement())
  profileId       Int       @unique @map("profile_id")
  status          String    // running | success | failed
  channelCount    Int       @default(0) @map("channel_count")
  programmeCount  Int       @default(0) @map("programme_count")
  error           String?
  startedAt       DateTime  @default(now()) @map("started_at")
  finishedAt      DateTime? @map("finished_at")

  profile CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("epg_refresh_logs")
}

/// Tracks the most recent (or in-progress) M3U refresh for a profile.
/// One row per profile — updated in place on each refresh.
model ChannelRefreshLog {
  id            Int      @id @default(autoincrement())
  profileId     Int      @unique @map("profile_id")
  status        String   // running | success | failed
  channelCount  Int      @default(0) @map("channel_count")
  error         String?
  startedAt     DateTime @default(now()) @map("started_at")
  finishedAt    DateTime? @map("finished_at")

  profile CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("channel_refresh_logs")
}

/// A code an end-user enters in the player to claim a playlist slot. The
/// code carries no credentials of its own — it points at a CredentialProfile.
model ActivationCode {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  status    String   @default("NotUsed")
  profileId Int      @map("profile_id")
  createdAt DateTime @default(now()) @map("created_at")

  profile CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@index([profileId])
  @@index([status])
  @@map("activation_codes")
}

/// A device that has logged into the player (auto-registered on first
/// activation). Carries no credentials — its playlists each own a profile.
model MacUser {
  id         Int    @id @default(autoincrement())
  macAddress String @unique @map("mac_address")
  title      String @default("")

  playlists Playlist[]
  favorites Favorite[]

  @@map("mac_users")
}

/// User-marked favorite channels, scoped to a (device, channel). Lives at
/// device level so a user signing into multiple devices doesn't share their
/// list — keeps the store simple and avoids cross-device sync questions.
model Favorite {
  id        Int      @id @default(autoincrement())
  macUserId Int      @map("mac_user_id")
  channelId Int      @map("channel_id")
  createdAt DateTime @default(now()) @map("created_at")

  macUser MacUser @relation(fields: [macUserId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([macUserId, channelId])
  @@index([macUserId])
  @@map("favorites")
}

/// A playlist on a device, pointing at the credentials it should use.
model Playlist {
  id         Int     @id @default(autoincrement())
  macUserId  Int     @map("mac_user_id")
  title      String?
  protection Boolean @default(false)
  pin        String?
  profileId  Int     @map("profile_id")

  macUser MacUser           @relation(fields: [macUserId], references: [id], onDelete: Cascade)
  profile CredentialProfile @relation(fields: [profileId], references: [id], onDelete: Restrict)

  @@index([macUserId])
  @@index([profileId])
  @@map("playlists")
}

model Trial {
  id         Int      @id @default(autoincrement())
  macAddress String   @map("mac_address")
  expireDate DateTime @map("expire_date")

  @@map("trials")
}

model Demo {
  id      Int    @id @default(autoincrement())
  mplname String @default("")
  mdns    String @default("")
  muser   String @default("")
  mpass   String @default("")
}

model Notification {
  id         Int    @id @default(autoincrement())
  messageOne String @default("") @map("message_one")
  messageTwo String @default("") @map("message_two")

  @@map("notifications")
}

model MacLength {
  id     Int @id @default(autoincrement())
  length Int @default(12)

  @@map("mac_length")
}

model Theme {
  id      Int    @id @default(autoincrement())
  themeNo String @default("theme_10") @map("theme_no")

  @@map("themes")
}

model LoginText {
  id            Int    @id @default(autoincrement())
  loginTitle    String @default("") @map("logintitial")
  loginSubtitle String @default("") @map("loginsubtitial")

  @@map("login_text")
}

model AdsSetting {
  id      Int    @id @default(autoincrement())
  adsType String @default("auto") @map("adstype")

  @@map("ads_settings")
}

model AutoLayout {
  id     Int    @id @default(autoincrement())
  layout String @default("layout_7")

  @@map("auto_layout")
}

model FrameLayout {
  id     Int    @id @default(autoincrement())
  layout String @default("layout_2")

  @@map("frame_layout")
}

model ManualAd {
  id    Int    @id @default(autoincrement())
  title String
  url   String

  @@map("manual_ads")
}

model League {
  id         Int    @id @default(autoincrement())
  leagueName String @map("league_name")
  leagueId   String @map("league_id")

  @@map("leagues")
}

model LeagueWidget {
  id         Int    @id @default(autoincrement())
  leagueName String @map("league_name")
  leagueId   String @map("league_id")

  @@map("league_widgets")
}

model Sport {
  id          Int    @id @default(autoincrement())
  api         String @default("")
  headerName  String @default("Event") @map("header_n")
  borderColor String @default("#000000") @map("border_c")
  bgColor     String @default("#000000") @map("background_c")
  textColor   String @default("#ffffff") @map("text_c")

  @@map("sports")
}

model TmdbApi {
  id      Int    @id @default(autoincrement())
  tmdbKey String @default("") @map("tmdbkey")

  @@map("tmdb_api")
}

model RemoteUpdate {
  id      Int    @id @default(autoincrement())
  version String @default("1.0") @map("nversion")
  url     String @default("") @map("nurl")

  @@map("remote_update")
}

/// Token-bucket rate limit storage. Composite key is "<ip>:<endpoint>" so
/// each (caller, endpoint) gets its own counter. Rows are upserted on every
/// hit and trimmed by a simple housekeeping query when convenient.
model RateLimit {
  key         String   @id
  count       Int      @default(0)
  windowStart DateTime @default(now()) @map("window_start")

  @@map("rate_limits")
}

/// Append-only log of admin mutations. One row per (admin user, action,
/// target) — used for compliance, debugging, and answering "who changed
/// what when" without paging through git history or Vercel logs.
model AuditLog {
  id           Int      @id @default(autoincrement())
  actorId      Int?     @map("actor_id")        // null = system / cron
  actorName    String   @default("system") @map("actor_name")
  action       String                                // e.g. "profile.update", "code.bulk_create"
  targetType   String?  @map("target_type")          // e.g. "CredentialProfile"
  targetId     String?  @map("target_id")
  metadata     Json?
  ip           String?
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}
