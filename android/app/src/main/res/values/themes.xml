<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.IboPlayerNext" parent="android:Theme.Material.Light.NoActionBar" />

    <!--
      Standalone theme used only when constructing MediaRouteButton.
      MediaRouterThemeHelper reads `colorPrimary` (the AppCompat attr, not
      the framework's `android:colorPrimary`) and computes a contrast ratio
      against white. Our activity theme inherits from the framework's
      Material theme, which leaves the AppCompat `colorPrimary` unresolved
      (returns 0 / fully transparent) and crashes the contrast check.
      We wrap the construction context with this theme to give the helper
      a known-good non-translucent primary + a solid window background.
    -->
    <style name="Theme.IboPlayerNext.MediaRouter" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#F59E29</item>
        <item name="android:colorPrimary">#F59E29</item>
        <item name="android:windowBackground">#111C2E</item>
    </style>
</resources>
